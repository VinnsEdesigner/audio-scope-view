{
  "name": "@audio-scope-view/api-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./domain": "./src/domain/index.ts",
    "./audioScopeView": "./src/audioScopeView/index.ts",
    "./audioScopeView/graphql": "./src/audioScopeView/graphql/index.ts",
    "./audioScopeView/graphql/queries": "./src/audioScopeView/graphql/queries/index.ts",
