# Audio Scope View Web App Environment Variables
# Copy this file to .env and fill in the values

# ============================================
# APP CONFIGURATION
# ============================================

# GraphQL Endpoint (default: /graphql for same-origin, or http://localhost:4000/graphql for remote)
VITE_GRAPHQL_ENDPOINT=/graphql

# WebSocket Endpoint for subscriptions
VITE_WEBSOCKET_ENDPOINT=ws://localhost:4000/graphql

# Bootstrap Key - Same key used by the server for initial client verification
# This should match the BOOTSTRAP_KEY in your server's .env
VITE_BOOTSTRAP_KEY=your-bootstrap-key-here

# Client URL - Used for CORS and callbacks
VITE_CLIENT_URL=http://localhost:3000

# ============================================
# BUILD CONFIGURATION (used by scripts/build.ts)
# ============================================

# Build mode: spa | ssr | all
# - spa: Static assets only (no SSR)
# - ssr: SPA + SSR bundle (default)
# - all: Same as ssr
BUILD_MODE=ssr

# Node environment: development | production
NODE_ENV=production

# Set to true to also build @audio-scope-view/api-client package
BUILD_API_CLIENT=false

# Skip client build (useful for SSR-only rebuilds)
SKIP_CLIENT=false

# Skip SSR build (useful for SPA-only rebuilds)
SKIP_SSR=false

# Clean dist before building (set to false for incremental builds)
CLEAN=true
